# URL canonico pubblico del sito, senza slash finale.
# Deve essere il dominio verificato in Search Console e Merchant Center.
NEXT_PUBLIC_SITE_URL=https://www.mirailabstore.com
NEXT_PUBLIC_APP_URL=https://www.mirailabstore.com

# Verifica facoltativa di Google Search Console (solo il valore del meta tag).
GOOGLE_SITE_VERIFICATION=

# Stripe: usa chiavi dello stesso ambiente (entrambe live oppure entrambe test)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Firma del webhook Stripe configurato su /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# Supabase admin scripts
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAIL=mattyventura02@gmail.com
ADMIN_PASSWORD=

# MIRA AI (server-side only: never expose this as NEXT_PUBLIC_*)
OPENAI_API_KEY=
OPENAI_MIRA_MODEL=gpt-5-mini
